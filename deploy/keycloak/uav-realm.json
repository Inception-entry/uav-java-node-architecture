{
  "realm": "uav",
  "displayName": "UAV Platform",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "description": "系统管理员"
      },
      {
        "name": "OPERATOR",
        "description": "巡检任务操作员"
      },
      {
        "name": "VIEWER",
        "description": "只读用户"
      }
    ]
  },
  "clients": [
    {
      "clientId": "uav-web",
      "name": "UAV Web",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8888/*"
      ],
      "webOrigins": [
        "http://localhost:8888"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "uav-web-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "uav-web",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "uav-service",
      "name": "UAV Service Account",
      "description": "用于脚本和后端服务通过 client_credentials 调用 UAV API",
      "enabled": true,
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "${UAV_SERVICE_CLIENT_SECRET}",
      "protocol": "openid-connect",
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "uav-service-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "uav-web",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "uav-admin",
      "enabled": true,
      "email": "uav-admin@local.test",
      "emailVerified": true,
      "firstName": "UAV",
      "lastName": "Administrator",
      "credentials": [
        {
          "type": "password",
          "value": "${UAV_DEV_USER_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "ADMIN"
      ]
    },
    {
      "username": "uav-operator",
      "enabled": true,
      "email": "uav-operator@local.test",
      "emailVerified": true,
      "firstName": "UAV",
      "lastName": "Operator",
      "credentials": [
        {
          "type": "password",
          "value": "${UAV_DEV_USER_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "OPERATOR"
      ]
    },
    {
      "username": "uav-viewer",
      "enabled": true,
      "email": "uav-viewer@local.test",
      "emailVerified": true,
      "firstName": "UAV",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "${UAV_DEV_USER_PASSWORD}",
          "temporary": false
        }
      ],
      "realmRoles": [
        "VIEWER"
      ]
    },
    {
      "username": "service-account-uav-service",
      "enabled": true,
      "serviceAccountClientId": "uav-service",
      "realmRoles": [
        "OPERATOR"
      ]
    }
  ]
}
